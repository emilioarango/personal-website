---
import MobileNav from "@components/MobileNav.astro";
import { SITE_CONFIG, SITE_CONTENT } from "@config";

const {
  title,
  description,
  lang,
  author,
  navLinks,
  socialLinks,
  socialImage,
  canonicalURL = new URL(Astro.url.pathname, Astro.site).href,
} = SITE_CONFIG;

const { name, specialty, summary, email } = SITE_CONTENT.hero;
const ogImgUrl = canonicalURL + socialImage;

const [firstName, ...rest] = name.split(" ");
const lastName = rest.join(" ");
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:image"       content={ogImgUrl} />

    <!-- Twitter / X card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:url"         content={canonicalURL} />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImgUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>

  <body style="background-color: var(--color-background); color: var(--color-text-muted);">

    <!-- Mobile nav (hidden on desktop) -->
    <MobileNav navLinks={navLinks} name={name} email={email} />

    <!-- Page wrapper -->
    <div class="mx-auto max-w-[1100px] px-6 md:px-12 lg:px-16">
      <div class="lg:flex lg:gap-12 lg:items-start">

        <!-- ── LEFT SIDEBAR (desktop only) ───────────────── -->
        <aside
          class="hidden lg:flex lg:flex-col lg:justify-between lg:w-[380px] lg:flex-shrink-0 lg:sticky lg:top-0 lg:max-h-screen lg:overflow-hidden lg:py-24"
        >
          <!-- Top: identity + nav -->
          <div>
            <!-- Name -->
            <a href="/" class="block mb-3">
              <h1
                class="text-4xl font-bold leading-tight"
                style="color: var(--color-text-primary); letter-spacing: -0.02em;"
              >
                {firstName}<br />{lastName}
              </h1>
            </a>

            <!-- Specialty -->
            <p
              class="mb-4 text-base font-medium"
              style="color: var(--color-text-muted);"
            >
              {specialty}
            </p>

            <!-- Tagline -->
            <p
              class="mb-12 text-sm leading-relaxed max-w-[280px]"
              style="color: var(--color-text-faint);"
            >
              {summary}
            </p>

            <!-- Vertical nav with animated line -->
            <nav aria-label="Main navigation">
              <ul class="flex flex-col gap-1">
                {
                  navLinks.map((link: { text: string; href: string }) => (
                    <li>
                      <a href={link.href} class="nav-link group flex items-center gap-4 py-2">
                        <span class="nav-line" />
                        <span
                          class="nav-text font-mono text-xs uppercase tracking-widest transition-colors duration-200"
                          style="color: var(--color-text-faint);"
                        >
                          {link.text}
                        </span>
                      </a>
                    </li>
                  ))
                }
              </ul>
            </nav>
          </div>

          <!-- Bottom: social links + email -->
          <div class="flex flex-col gap-4">
            <a
              href={`mailto:${email}`}
              class="social-link font-mono text-xs transition-colors duration-150"
              style="color: var(--color-text-faint);"
            >
              {email}
            </a>
            <div class="flex gap-5">
              {
                socialLinks.map(({ text, href }: { text: string; href: string }) => (
                  <a
                    href={href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="social-link font-mono text-xs transition-colors duration-150"
                    style="color: var(--color-text-faint);"
                  >
                    {text} ↗
                  </a>
                ))
              }
            </div>
          </div>
        </aside>

        <!-- ── RIGHT CONTENT (scrollable) ───────────────── -->
        <main class="flex-1 min-w-0 py-16 lg:py-24">
          <slot />
        </main>

      </div>
    </div>

  </body>
</html>

<script>
  // Sidebar nav: active section highlighting
  const navLinks = document.querySelectorAll(".nav-link");

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          navLinks.forEach((link) => {
            const isActive = link.getAttribute("href") === `#${entry.target.id}`;
            link.classList.toggle("is-active", isActive);
            const text = link.querySelector(".nav-text") as HTMLElement | null;
            if (text) {
              text.style.color = isActive
                ? "var(--color-accent)"
                : "var(--color-text-faint)";
            }
          });
        }
      });
    },
    { threshold: 0.3, rootMargin: "-80px 0px -200px 0px" },
  );

  document
    .querySelectorAll("section[id]")
    .forEach((s) => observer.observe(s));
</script>

<style>
  /* Animated nav line */
  .nav-line {
    display: block;
    height: 1px;
    width: 32px;
    background-color: var(--color-text-faint);
    transition: width 200ms ease, background-color 200ms ease;
    flex-shrink: 0;
  }

  .nav-link:hover .nav-line,
  .nav-link.is-active .nav-line {
    width: 64px;
    background-color: var(--color-accent);
  }

  .nav-link:hover .nav-text {
    color: var(--color-accent) !important;
  }

  .social-link:hover {
    color: var(--color-accent) !important;
  }
</style>
