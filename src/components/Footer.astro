---
import type { SiteConfig } from "@types";

type Props = Pick<SiteConfig, "author" | "socialLinks">;
const { author, socialLinks } = Astro.props;

const currentYear = new Date().getFullYear();
---

<footer
  class="w-full px-5 py-10"
  style="border-top: 1px solid var(--color-border);"
>
  <div class="mx-auto flex max-w-3xl flex-col items-center gap-6 sm:flex-row sm:justify-between">

    <!-- Copyright -->
    <p
      class="font-mono text-xs"
      style="color: var(--color-text-faint);"
    >
      © {currentYear} {author}
    </p>

    <!-- Social links -->
    <ul class="flex items-center gap-5">
      {
        socialLinks.map(({ text, href }: { text: string; href: string }) => (
          <li>
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              class="social-link font-mono text-xs transition-colors duration-150"
              style="color: var(--color-text-faint);"
            >
              {text} ↗
            </a>
          </li>
        ))
      }
    </ul>

  </div>
</footer>

<style>
  .social-link:hover {
    color: var(--color-text-primary) !important;
  }
</style>
