---
import type { SiteConfig } from "@types";
type Props = Pick<SiteConfig, "author" | "socialLinks">;
const { author, socialLinks } = Astro.props;
const currentYear = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-links">
      {socialLinks.map(({ text, href }) => (
        <a href={href} target="_blank" rel="noopener noreferrer" class="footer-link">
          {text} <span aria-hidden="true">↗</span>
        </a>
      ))}
    </div>
    <p class="footer-copy">{author} &copy; {currentYear}</p>
  </div>
</footer>
<style>
.site-footer { padding: 3rem 0 1.5rem; border-top: 1px solid var(--color-border); margin-top: 4rem; }
.footer-inner { display: flex; justify-content: space-between; align-items: center; gap: 1.5rem; flex-wrap: wrap; }
.footer-links { display: flex; gap: 1.5rem; }
.footer-link { font-family: var(--font-display); font-size: 0.6rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--color-text-muted); text-decoration: none; transition: color 150ms; }
.footer-link:hover { color: var(--color-accent); }
.footer-copy { font-family: var(--font-display); font-size: 0.58rem; letter-spacing: 0.12em; color: var(--color-text-faint); }
</style>
