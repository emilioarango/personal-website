---
import Section from "./Section.astro";
import type { ProjectProps } from "@types";

interface Props {
  projects: ProjectProps[];
}

const { projects } = Astro.props;
---

{
  projects.length > 0 && (
    <Section text="Projects" href="projects">
      <div class="flex flex-col gap-6">
        {projects.map(({ name, summary, linkPreview, linkSource }) => (
          <div
            class="rounded-lg p-6 transition-colors duration-200"
            style="
              background-color: var(--color-surface);
              border: 1px solid var(--color-border);
            "
          >
            <h3
              class="mb-2 text-base font-semibold"
              style="color: var(--color-text-primary);"
            >
              {name}
            </h3>
            <p
              class="mb-4 text-sm leading-relaxed"
              style="color: var(--color-text-muted);"
            >
              {summary}
            </p>
            <div class="flex gap-4">
              {linkPreview && (
                <a
                  href={linkPreview}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-mono text-xs transition-colors duration-150"
                  style="color: var(--color-accent);"
                >
                  Preview ↗
                </a>
              )}
              {linkSource && (
                <a
                  href={linkSource}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-mono text-xs transition-colors duration-150"
                  style="color: var(--color-text-faint);"
                >
                  Source ↗
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    </Section>
  )
}
