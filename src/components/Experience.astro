---
import Section from "./Section.astro";
import type { ExperienceProps } from "@types";

interface Props {
  experience: ExperienceProps[];
}

const { experience } = Astro.props;
---

<Section text="Experience" href="experience">
  <div class="flex flex-col gap-10">
    {
      experience.map(({ company, position, startDate, endDate, summary }) => (
        <div
          class="group relative border-l pl-6 transition-colors duration-200"
          style="border-color: var(--color-border);"
        >
          <!-- Timeline dot -->
          <span
            class="absolute -left-[5px] top-[6px] h-[9px] w-[9px] rounded-full border-2 transition-colors duration-200"
            style="
              background-color: var(--color-surface-2);
              border-color: var(--color-border-muted);
            "
          />

          <!-- Header row -->
          <div class="mb-3 flex flex-col gap-0.5">
            <h3
              class="text-base font-semibold leading-snug"
              style="color: var(--color-text-primary);"
            >
              {position}
            </h3>
            <div class="flex items-center gap-2">
              <span
                class="text-sm font-medium"
                style="color: var(--color-accent);"
              >
                {company}
              </span>
              <span style="color: var(--color-border-muted);" aria-hidden="true">·</span>
              <span
                class="font-mono text-xs"
                style="color: var(--color-text-faint);"
              >
                {startDate} – {endDate}
              </span>
            </div>
          </div>

          <!-- Summary -->
          {Array.isArray(summary) ? (
            <ul class="flex flex-col gap-2">
              {summary.map((item: string) => (
                <li
                  class="flex gap-3 text-sm leading-relaxed"
                  style="color: var(--color-text-muted);"
                >
                  <span
                    class="mt-[0.35rem] h-1 w-1 flex-shrink-0 rounded-full"
                    style="background-color: var(--color-text-faint);"
                    aria-hidden="true"
                  />
                  {item}
                </li>
              ))}
            </ul>
          ) : (
            <p
              class="text-sm leading-relaxed"
              style="color: var(--color-text-muted);"
            >
              {summary}
            </p>
          )}
        </div>
      ))
    }
  </div>
</Section>
