---
import Section from "./Section.astro";
import type { ExperienceProps } from "@types";
interface Props { experience: ExperienceProps[]; }
const { experience } = Astro.props;
---
<Section text="Experience" href="experience">
  <div class="exp-list">
    {experience.map(({ company, position, startDate, endDate, summary }, index) => (
      <div class="exp-card">
        <div class="exp-header">
          <div class="exp-title-block">
            <h3 class="company">{company}</h3>
            <p class="position">{position}</p>
          </div>
          <span class="dates">{startDate} — {endDate}</span>
        </div>
        {Array.isArray(summary) ? (
          <ul class="bullets">
            {summary.map((item) => (<li class="bullet-item">{item}</li>))}
          </ul>
        ) : (<p class="body-text">{summary}</p>)}
        {index < experience.length - 1 && <hr class="card-divider" />}
      </div>
    ))}
  </div>
</Section>
<style>
.exp-list { display: flex; flex-direction: column; }
.exp-card { padding: 0 0 0 1.25rem; border-left: 2px solid var(--color-border); transition: border-color 250ms ease; }
.exp-card:hover { border-left-color: var(--color-accent); }
.exp-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; margin-bottom: 1.25rem; }
.exp-title-block { display: flex; flex-direction: column; gap: 0.35rem; }
.company { font-family: var(--font-display); font-size: 1.25rem; font-weight: 600; color: var(--color-text-primary); letter-spacing: 0.06em; line-height: 1.1; }
.position { font-family: var(--font-display); font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--color-accent); }
.dates { font-family: var(--font-display); font-size: 0.6rem; letter-spacing: 0.12em; color: var(--color-text-muted); white-space: nowrap; padding-top: 0.2rem; }
.bullets { list-style: none; display: flex; flex-direction: column; gap: 0.6rem; padding: 0; margin: 0; }
.bullet-item { position: relative; padding-left: 1.25rem; font-family: var(--font-sans); font-size: 1rem; line-height: 1.65; color: var(--color-text-secondary); }
.bullet-item::before { content: "—"; position: absolute; left: 0; top: 0; color: var(--color-accent); font-size: 0.75rem; line-height: 1.8; }
.body-text { font-family: var(--font-sans); font-size: 1rem; line-height: 1.65; color: var(--color-text-secondary); }
.card-divider { border: none; border-top: 1px solid var(--color-border); margin: 2.5rem 0; }
</style>
