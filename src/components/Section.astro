---
interface Props {
  text: string;
  href: string;
}

const { text, href } = Astro.props;
---

<section id={href} class="py-20">
  <div class="section-heading">
    <h2
      class="text-xl font-semibold tracking-tight"
      style="color: var(--color-text-primary);"
    >
      {text}
    </h2>
  </div>
  <slot />
</section>
