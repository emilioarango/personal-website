---
interface Props {
  text: string;
  href: string;
}
const { text, href } = Astro.props;
---
<section id={href} class="section">
  <div class="section-header">
    <h2>{text}</h2>
    <div class="accent-bar"></div>
  </div>
  <slot />
</section>
<style>
.section { padding: 4.5rem 0; }
.section-header { margin-bottom: 3rem; }
h2 { font-family: var(--font-display); font-size: clamp(2.25rem, 5vw, 3.25rem); font-weight: 600; color: var(--color-text-primary); letter-spacing: 0.06em; line-height: 1; margin-bottom: 0.875rem; }
.accent-bar { width: 3rem; height: 3px; background: var(--color-accent); }
</style>
