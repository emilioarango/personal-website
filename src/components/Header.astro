---
import Menu from "@icons/Menu.astro";
import type { HeaderProps } from "@types";

type Props = HeaderProps;
const { navLinks } = Astro.props;
---

<header
  id="site-header"
  class="sticky top-0 z-50 w-full transition-all duration-300"
  style="border-bottom: 1px solid transparent;"
>
  <div class="mx-auto flex max-w-3xl items-center justify-between px-5 py-4">

    <!-- Logo -->
    <a
      href="/"
      aria-label="Home"
      class="logo font-mono text-sm font-medium tracking-tight transition-colors duration-150"
      style="color: var(--color-text-primary);"
    >
      EA
    </a>

    <!-- Mobile menu toggle -->
    <button
      type="button"
      id="menu-button"
      class="px-1.5 sm:hidden"
      style="color: var(--color-text-muted);"
      aria-expanded="false"
      aria-controls="main-menu"
    >
      <Menu />
    </button>

    <!-- Nav -->
    <nav
      id="main-menu"
      class="absolute top-[57px] right-4 hidden rounded-lg px-2 py-2 sm:static sm:block sm:p-0"
      style="
        background-color: var(--color-surface-2);
        border: 1px solid var(--color-border);
      "
    >
      <ul class="gap-1 sm:flex">
        {
          navLinks.map((link: { text: string; href: string }) => (
            <li>
              <a
                href={link.href}
                class="nav-item block rounded px-3 py-1.5 text-sm font-medium transition-colors duration-150"
                style="color: var(--color-text-faint);"
              >
                {link.text}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<script>
  const header  = document.querySelector("#site-header") as HTMLElement;
  const button  = document.querySelector("#menu-button");
  const menu    = document.querySelector("#main-menu");
  const navItems = document.querySelectorAll("#main-menu .nav-item");

  // Scroll-based header background
  window.addEventListener("scroll", () => {
    const scrolled = window.scrollY > 10;
    if (header) {
      header.style.backgroundColor = scrolled
        ? "rgba(10,10,10,0.85)"
        : "transparent";
      header.style.backdropFilter = scrolled ? "blur(12px)" : "none";
      header.style.borderBottomColor = scrolled
        ? "var(--color-border)"
        : "transparent";
    }
  }, { passive: true });

  // Mobile toggle
  const toggleMenu = () => {
    menu?.classList.toggle("hidden");
    const isHidden = menu?.classList.contains("hidden");
    button?.setAttribute("aria-expanded", `${!isHidden}`);
  };
  button?.addEventListener("click", toggleMenu);
  navItems.forEach((item) => item.addEventListener("click", toggleMenu));

  // Active nav highlight on scroll
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          navItems.forEach((item) => {
            const isActive = item.getAttribute("href") === `#${entry.target.id}`;
            (item as HTMLElement).style.color = isActive
              ? "var(--color-text-primary)"
              : "var(--color-text-faint)";
          });
        }
      });
    },
    { threshold: 0.5 },
  );

  document.querySelectorAll("section").forEach((s) => observer.observe(s));

  document.onvisibilitychange = () => {
    if (document.visibilityState === "hidden") {
      observer.disconnect();
    } else {
      document.querySelectorAll("section").forEach((s) => observer.observe(s));
    }
  };
</script>

<style>
  /* Mobile menu: remove card styling on sm+ */
  @media (min-width: 640px) {
    #main-menu {
      border: none !important;
      background-color: transparent !important;
    }
  }

  .logo:hover {
    color: var(--color-accent) !important;
  }

  .nav-item:hover {
    color: var(--color-text-primary) !important;
  }
</style>
